# VAOS-Kernel Environment Variables

# gRPC listen address (default: 0.0.0.0:50051)
VAOS_KERNEL_GRPC_ADDR=0.0.0.0:50051

# HTTP/WebSocket listen address (default: 0.0.0.0:8080)
VAOS_KERNEL_WS_ADDR=0.0.0.0:8080

# Attestation mode: sync | async | db-sync | db-async (default: sync)
VAOS_KERNEL_MODE=sync

# JWT signing key (required for production; if unset, a random key is generated per-run)
# VAOS_JWT_SECRET=your-secret-key-here-min-32-bytes

# API secret for HTTP endpoint auth (if unset, endpoints are unauthenticated — dev mode)
# VAOS_API_SECRET=your-api-secret-here

# PostgreSQL connection (used by DefaultConfig; falls back to localhost defaults)
# VAOS_DB_HOST=localhost
# VAOS_DB_PORT=5432
# VAOS_DB_USER=postgres
# VAOS_DB_PASSWORD=vaos
# VAOS_DB_NAME=vaos

# PostgreSQL DSN (required for db-sync and db-async modes)
# VAOS_DB_DSN=host=localhost user=postgres dbname=vaos_kernel sslmode=disable

# AMQP URL for telemetry (optional; defaults to guest:guest@localhost — NOT for production)
# AMQP_URL=amqp://guest:guest@localhost:5672
